.vscode/
.idea/

# Testing
.pytest_cache/
.coverage
htmlcov/

# Local scratch — config-generator verification scripts + their build outputs
generated/
.tmp_jsdom/
.tmp_cr_build/
# Session-local scratch: repro/probe/audit dirs + files, build logs (never source)
.tmp*
.cr_audit/
tmp_cr_audit/
_cr_audit_probe*.py
build_stderr.txt

# Node — only for the headless JS tests (jsdom). Install once with
# `npm install jsdom`; tests/test_generate_nav.py skips when jsdom is absent.
node_modules/
package-lock.json

# Flask runtime data (per-deployment user state, history snapshots, SQLite indexes)
instance/
instance.bak.*/

# OS
.DS_Store
Thumbs.db

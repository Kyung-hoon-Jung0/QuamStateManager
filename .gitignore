*.py[cod]
*.egg-info/
*.egg
.eggs/

# Virtual environments
.venv/
venv/

# PyInstaller build artifacts
dist/
build/
# ...but the hand-written PyInstaller spec is source, not an artifact
!build/
build/*
!build/quam-manager.spec

# Screenshots / reference images
*.png

# Claude Code
.claude/
